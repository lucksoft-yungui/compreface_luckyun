registry=exadel/
backend_registry=10.10.10.52:4000/
ui_registry=10.10.10.52:4000/
postgres_username=system #postgres
postgres_password=luckserver #postgres
postgres_db=frs
# admin/api 容器连接 PostgreSQL 使用的地址。可配置为 RDS/独立 PG/内网域名。
postgres_host=host.docker.internal
postgres_port=54321 #5432
postgres_storage_path=/Users/cedric/Cedric/data/compreFace/postgresql/data
email_host=smtp.gmail.com
email_username=
email_from=
email_password=
enable_email_server=false
save_images_to_db=true
compreface_api_java_options=-Xmx4g
compreface_admin_java_options=-Xmx1g
max_file_size=5MB
max_request_size=10M
max_detect_size=640
uwsgi_processes=2
uwsgi_threads=1
connection_timeout=10000
read_timeout=60000
ADMIN_VERSION=1.2.0-luck
API_VERSION=1.2.0-luck
LOCAL_IMAGE_VERSION=1.2.0-luck
ND4J_CLASSIFIER=
FE_VERSION=1.2.0
UI_VERSION=1.2.0
LOCAL_UI_VERSION=1.0.0-luck
# luck-ui 在容器内部通过 Nginx 代理的后端地址
luck_ui_admin_upstream=http://compreface-admin:8080
luck_ui_api_upstream=http://compreface-api:8080
luck_ui_core_upstream=http://compreface-core:3000
# 默认启用 CPU core；如需 GPU，启动命令前覆盖 COMPOSE_PROFILES=gpu。
COMPOSE_PROFILES=cpu
CORE_CPU_VERSION=1.2.0-arcface-r100
CORE_GPU_VERSION=1.2.0-arcface-r100-gpu
CORE_GPU_IDX=0
POSTGRES_VERSION=1.2.0
